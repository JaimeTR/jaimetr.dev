# Configuración del entorno
# Copia este archivo a .env.local y actualiza los valores según tu configuración

# URL de la aplicación en producción
NEXT_PUBLIC_SITE_URL=https://jaimetr.dev

# API externa (si la necesitas)
# NEXT_PUBLIC_API_URL=https://api.jaimetr.dev/api/v1
# NEXT_PUBLIC_BASE_API_URL=https://api.jaimetr.dev

# Google Analytics 4
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# SMTP para envio de correos (2FA)
# SMTP_HOST=smtp.titan.email
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=notificaciones@jaimetr.dev
# SMTP_PASS=tu_password
# SMTP_FROM=notificaciones@jaimetr.dev

# Clave de IA (OpenAI)
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Proveedor de IA: gemini | openai
AI_PROVIDER=gemini

# Clave de IA (Gemini)
# GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modelo de Gemini (por defecto Pro)
AI_GEMINI_MODEL=gemini-1.5-pro

# Supabase (opcional para guardar metadatos de posts)
# SUPABASE_URL=https://xxxxx.supabase.co
# SUPABASE_ANON_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
